{
  "manifest_version": 3,
  "name": "PhishGuard AI",
  "version": "2.0.0",
  "description": "Real-time phishing detection for Gmail and the web. Scan emails, analyse links, and stay protected.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://phishguard-okmkdupa4om23rq6e78bad.streamlit.app/*",
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
