{
  "manifest_version": 3,
  "name": "PhishGuard AI",
  "version": "3.0.0",
  "description": "Enterprise phishing detection for Gmail and the web. Right-click any text to scan. Powered by SecOpsNode AI.",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://huggingface.co/spaces/Sabersouihi/phishguard-ai/*",
    "http://127.0.0.1:8501/*",
    "http://127.0.0.1:8080/*",
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
