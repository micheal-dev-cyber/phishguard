# PhishGuard AI — Environment Configuration
# Copy to .env and fill in your values

# ── REQUIRED ──────────────────────────────────────────────
# SMTP for email verification, password reset, alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# App URL (used in verification/reset links)
APP_URL=http://localhost:8501

# ── AI PROVIDERS (at least one required for AI features) ──
# Groq (free tier available)
GROQ_API_KEY=
# OpenRouter (free tier available)
OPENROUTER_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=

# ── THREAT INTELLIGENCE ───────────────────────────────────
VIRUSTOTAL_API_KEY=

# ── MICROSOFT 365 (Graph API - app-only) ─────────────────
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# ── GMAIL OAUTH ───────────────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8501

# ── PADDLE BILLING ────────────────────────────────────────
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_STARTER=
PADDLE_PRICE_ID_BUSINESS=
PADDLE_PRICE_ID_CONSULTANT=
PADDLE_PRICE_ID_ENTERPRISE=
PADDLE_ENVIRONMENT=sandbox

# ── POSTGRESQL (optional — defaults to SQLite) ───────────
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=

# ── SIEM INTEGRATIONS (optional) ─────────────────────────
SIEM_SPLUNK_HEC_URL=
SIEM_SPLUNK_HEC_TOKEN=
SIEM_ELASTIC_CLOUD_ID=
SIEM_ELASTIC_API_KEY=

# ── MISC ─────────────────────────────────────────────────
LOG_LEVEL=INFO
ADMIN_PASSWORD=
