# ──────────────────────────────────────────────────────────────────────────────
# PhishGuard AI — Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real secrets.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Providers (at least one required) ────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Threat Intel ─────────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=

# ── Google Services (Safe Browsing, reCAPTCHA, OAuth) ───────────────────────
GOOGLE_API_KEY=

# ── Payment Processing ───────────────────────────────────────────────────────
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=
SMTP_PASSWORD=

# ── SSO / OIDC (optional) ────────────────────────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_AUTHORITY=https://login.microsoftonline.com/common
OAUTH_REDIRECT_URI=https://phishguard.ai/callback

# ── Microsoft Graph (optional — replaces IMAP password auth) ────────────────
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# ── PostgreSQL (optional — replaces SQLite for production) ──────────────────
PGHOST=
PGPORT=5432
PGDATABASE=phishguard
PGUSER=
PGPASSWORD=

# ── SIEM Webhook Targets (optional) ─────────────────────────────────────────
SIEM_SPLUNK_HEC_URL=
SIEM_SPLUNK_HEC_TOKEN=
SIEM_ELASTIC_CLOUD_ID=
SIEM_ELASTIC_API_KEY=
SIEM_QRAZAR_URL=
SIEM_QRAZAR_API_KEY=

# ── Admin / Defaults ─────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme
APP_URL=https://phishguard.ai
